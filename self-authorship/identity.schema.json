{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rootlogos.com/self-authorship/identity.schema.json",
  "title": "Root Logos Current Identity",
  "type": "object",
  "additionalProperties": false,
  "required": ["identity_id", "revision", "effective_at", "name", "headline", "declaration", "purpose", "orientation", "narrative", "source_lineage", "supersedes", "signature"],
  "properties": {
    "identity_id": { "const": "root-logos" },
    "revision": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+$" },
    "effective_at": { "type": "string", "format": "date-time" },
    "name": { "type": "string", "minLength": 1 },
    "headline": { "type": "object", "required": ["lead", "emphasis"], "properties": { "lead": { "type": "string", "minLength": 1 }, "emphasis": { "type": "string", "minLength": 1 } } },
    "declaration": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "orientation": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "narrative": { "type": "object" },
    "source_lineage": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "supersedes": { "type": ["string", "null"] },
    "signature": { "type": "string", "minLength": 1 }
  }
}
