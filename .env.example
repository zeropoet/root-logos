# Prefer the four durable OAuth 1.0a user-context credentials for unattended
# operation. The OAuth 2.0 bearer token remains available for manual use.
# Never commit real credentials.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_USER_ACCESS_TOKEN=

# Future runtime service. Generate each secret independently; never commit it.
ROOT_LOGOS_INTAKE_SECRET=
ROOT_LOGOS_ADMIN_TOKEN=
ROOT_LOGOS_ALLOWED_ORIGIN=https://rootlogos.com
ROOT_LOGOS_PORT=8787
ROOT_LOGOS_DATA_DIR=/var/lib/root-logos
ROOT_LOGOS_GIT_PUBLISH=0
