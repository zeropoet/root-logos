{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rootlogos.com/resonance/score.schema.json",
  "title": "Root Logos Resonant Score",
  "type": "object",
  "required": ["schema", "seed", "signature", "tempo", "sources", "events"],
  "properties": {
    "schema": { "const": "resonant-score/v1" },
    "seed": { "type": "integer", "minimum": 0 },
    "signature": { "type": "string", "pattern": "^[0-9a-f]{8}$" },
    "tempo": { "type": "number", "minimum": 42, "maximum": 68 },
    "sources": { "type": "array", "minItems": 1 },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["voice", "provenance", "frequency", "beats", "rest"],
        "properties": {
          "voice": { "enum": ["constitution", "relation", "inquiry", "memory", "threshold", "breath"] },
          "provenance": { "type": "string", "minLength": 1 },
          "frequency": { "type": "number", "exclusiveMinimum": 0 },
          "beats": { "type": "number", "exclusiveMinimum": 0 },
          "rest": { "type": "boolean" }
        }
      }
    }
  }
}
